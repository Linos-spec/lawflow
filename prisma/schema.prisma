generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────

enum UserRole {
  ADMIN
  PARTNER
  ASSOCIATE
  PARALEGAL
}

enum CaseStatus {
  OPEN
  ACTIVE
  ON_HOLD
  PENDING
  CLOSED
  ARCHIVED
}

enum CaseType {
  CIVIL
  CRIMINAL
  FAMILY
  CORPORATE
  IMMIGRATION
  REAL_ESTATE
  BANKRUPTCY
  PERSONAL_INJURY
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ClientType {
  INDIVIDUAL
  BUSINESS_ENTITY
  GOVERNMENT
}

enum DeadlineType {
  FILING
  COURT_APPEARANCE
  DISCOVERY
  STATUTE_OF_LIMITATIONS
  CLIENT_MEETING
  INTERNAL
  OTHER
}

enum DeadlineStatus {
  PENDING
  COMPLETED
  OVERDUE
  CANCELLED
}

enum BillingType {
  HOURLY
  FLAT_FEE
  CONTINGENCY
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OUTSTANDING
  OVERDUE
  VOID
}

enum IntakeStatus {
  PENDING
  IN_REVIEW
  CONVERTED
  REJECTED
  COMPLETED
}

// ─── MULTI-TENANCY ─────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  firms Firm[]
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String
  role           UserRole @default(ASSOCIATE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  firmId String?
  firm   Firm?   @relation(fields: [firmId], references: [id])

  timeEntries TimeEntry[]
  auditLogs   AuditLog[]

  @@index([organizationId])
  @@index([email])
}

model Firm {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  users          User[]
  clients        Client[]
  cases          Case[]
  deadlines      Deadline[]
  billingRecords BillingRecord[]
  timeEntries    TimeEntry[]
  intakeForms    IntakeForm[]

  @@index([organizationId])
}

// ─── BUSINESS ENTITIES ─────────────────────────────

model Client {
  id          String     @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  clientType  ClientType @default(INDIVIDUAL)
  company     String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  cases          Case[]
  billingRecords BillingRecord[]
  intakeForms    IntakeForm[]

  @@index([firmId])
}

model Case {
  id          String     @id @default(cuid())
  caseNumber  String
  title       String
  description String?
  status      CaseStatus @default(OPEN)
  caseType    CaseType   @default(CIVIL)
  priority    Priority   @default(MEDIUM)
  filingDate  DateTime?
  closingDate DateTime?
  courtName   String?
  judgeName   String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  deadlines      Deadline[]
  billingRecords BillingRecord[]
  timeEntries    TimeEntry[]

  @@unique([firmId, caseNumber])
  @@index([firmId])
  @@index([clientId])
  @@index([status])
}

model Deadline {
  id           String         @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime
  deadlineType DeadlineType   @default(OTHER)
  status       DeadlineStatus @default(PENDING)
  priority     Priority       @default(MEDIUM)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([caseId])
  @@index([dueDate])
  @@index([status])
}

model BillingRecord {
  id            String        @id @default(cuid())
  invoiceNumber String
  billingType   BillingType   @default(HOURLY)
  totalAmount   Decimal       @db.Decimal(19, 4)
  paidAmount    Decimal       @default(0) @db.Decimal(19, 4)
  paymentStatus PaymentStatus @default(UNPAID)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  lineItems BillingLineItem[]

  @@unique([firmId, invoiceNumber])
  @@index([firmId])
  @@index([clientId])
  @@index([caseId])
  @@index([paymentStatus])
}

model BillingLineItem {
  id          String  @id @default(cuid())
  description String
  quantity    Decimal @db.Decimal(10, 2)
  rate        Decimal @db.Decimal(19, 4)
  amount      Decimal @db.Decimal(19, 4)

  billingRecordId String
  billingRecord   BillingRecord @relation(fields: [billingRecordId], references: [id], onDelete: Cascade)

  @@index([billingRecordId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  description String
  hours       Decimal  @db.Decimal(10, 2)
  rate        Decimal  @db.Decimal(19, 4)
  date        DateTime
  billable    Boolean  @default(true)
  billed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([caseId])
  @@index([userId])
  @@index([date])
}

model IntakeForm {
  id                String       @id @default(cuid())
  prospectName      String
  prospectEmail     String?
  prospectPhone     String?
  caseType          CaseType     @default(OTHER)
  description       String?
  status            IntakeStatus @default(PENDING)
  conflictCheck     Boolean      @default(false)
  engagementLetter  Boolean      @default(false)
  idVerification    Boolean      @default(false)
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  @@index([firmId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity, entityId])
}
